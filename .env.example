# ===== AI Ecosystem environment (template) =====
# Copy this file to ".env" and fill in your own values.
# The real .env is git-ignored so secrets are never committed.

# Server
HOST=127.0.0.1
PORT=8000
RELOAD=true

# Ollama (local AI) — OLLAMA_MODEL is the single place to change the model
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5
OLLAMA_TIMEOUT=120

# Claude API (optional — leave blank to use Ollama only)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8

# Groq API (optional — fast hosted Llama)
GROQ_API=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# CORS (comma separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
